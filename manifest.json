{
  "manifest_version": 3,
  "name": "TabVault",
  "version": "1.0.0",
  "description": "Save all open tabs in one click. Organize, remind, restore.",
  "permissions": ["tabs", "storage", "alarms", "notifications"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
